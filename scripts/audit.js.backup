const hre = require("hardhat");

async function main() {
  const [owner, attacker, player1, player2] = await hre.ethers.getSigners();
  console.log("=== AUDIT LOOKA LOTTERY ===\n");
  let passed = 0;
  let failed = 0;

  // Déploiement
  const MockVRF  = await hre.ethers.getContractFactory("MockVRFCoordinator");
  const mockVRF  = await MockVRF.deploy();
  const MockUSDT = await hre.ethers.getContractFactory("MockUSDT");
  const usdt     = await MockUSDT.deploy();
  const Lottery  = await hre.ethers.getContractFactory("LotteryV1");
  const lottery  = await Lottery.deploy(
    await usdt.getAddress(), await mockVRF.getAddress(),
    "0xd4bb89654db74673a187bd804519e65e3f71a52bc55f11da7601a13dcf505314", 1n
  );

  const lotteryAddr = await lottery.getAddress();
  await usdt.mint(player1.address, 1000n * 1000000n);
  await usdt.mint(player2.address, 1000n * 1000000n);
  await usdt.connect(player1).approve(lotteryAddr, 1000n * 1000000n);
  await usdt.connect(player2).approve(lotteryAddr, 1000n * 1000000n);

  function ok(msg)   { console.log(`  ✅ ${msg}`); passed++; }
  function fail(msg) { console.log(`  ❌ ${msg}`); failed++; }

  // ─── TEST 1 : Access Control ───
  console.log("1. ACCESS CONTROL");
  try {
    await lottery.connect(attacker).requestHourlyDraw();
    fail("requestHourlyDraw accessible par non-owner");
  } catch { ok("requestHourlyDraw protégé (onlyOwner)"); }

  try {
    await lottery.connect(attacker).requestDailyDraw();
    fail("requestDailyDraw accessible par non-owner");
  } catch { ok("requestDailyDraw protégé (onlyOwner)"); }

  try {
    await lottery.connect(attacker).withdrawHouse(attacker.address, 1n);
    fail("withdrawHouse accessible par non-owner");
  } catch { ok("withdrawHouse protégé (onlyOwner)"); }

  try {
    await lottery.connect(attacker).updateParams(1n, 1n);
    fail("updateParams accessible par non-owner");
  } catch { ok("updateParams protégé (onlyOwner)"); }

  try {
    await lottery.connect(attacker).updateDistribution(8800n,300n,200n,100n,600n,50n);
    fail("updateDistribution accessible par non-owner");
  } catch { ok("updateDistribution protégé (onlyOwner)"); }

  // ─── TEST 2 : Distribution ───
  console.log("\n2. DISTRIBUTION DES FONDS");
  await lottery.connect(player1).buyTickets(100n, hre.ethers.ZeroAddress);

  const prize   = await lottery.getCurrentPrize();
  const daily   = await lottery.jackpotDaily();
  const weekly  = await lottery.jackpotWeekly();
  const monthly = await lottery.jackpotMonthly();
  const house   = await lottery.houseBalance();
  const total   = prize + daily + weekly + monthly + house;
  const expected = 100n * 1000000n;

  if (total === expected) {
    ok(`Distribution correcte: ${total} = ${expected}`);
  } else {
    fail(`Distribution incorrecte: ${total} != ${expected}`);
  }

  const prizeExpected = (100n * 1000000n * 8800n) / 10000n;
  if (prize === prizeExpected) {
    ok(`Cagnotte horaire correcte: ${prize / 1000000n} USDT`);
  } else {
    fail(`Cagnotte horaire incorrecte: ${prize} != ${prizeExpected}`);
  }

  // ─── TEST 3 : Seuil minimum ───
  console.log("\n3. SEUIL MINIMUM");
  const freshLottery = await Lottery.deploy(
    await usdt.getAddress(), await mockVRF.getAddress(),
    "0xd4bb89654db74673a187bd804519e65e3f71a52bc55f11da7601a13dcf505314", 1n
  );
  await usdt.connect(player1).approve(await freshLottery.getAddress(), 1000n * 1000000n);
  await freshLottery.connect(player1).buyTickets(10n, hre.ethers.ZeroAddress);

  const tx      = await freshLottery.requestHourlyDraw();
  const receipt = await tx.wait();
  let skipped   = false;
  for (const log of receipt.logs) {
    try {
      const p = freshLottery.interface.parseLog(log);
      if (p.name === "RoundSkipped") skipped = true;
    } catch {}
  }
  if (skipped) {

    ok("Tirage sauté correctement si seuil non atteint");
  } else {
    fail("Tirage lancé sans seuil minimum atteint");
  }

  // ─── TEST 4 : Parrainage ───
  console.log("\n4. PARRAINAGE");
  const lottery2 = await Lottery.deploy(
    await usdt.getAddress(), await mockVRF.getAddress(),
    "0xd4bb89654db74673a187bd804519e65e3f71a52bc55f11da7601a13dcf505314", 1n
  );
  const l2addr = await lottery2.getAddress();
  await usdt.connect(player2).approve(l2addr, 1000n * 1000000n);
  await lottery2.connect(player2).buyTickets(10n, player1.address);

  const refPending = await lottery2.pendingReferral(player1.address);
  const expected_ref = (10n * 1000000n * 50n) / 10000n;
  if (refPending === expected_ref) {
    ok(`Parrainage correct: ${refPending} = ${expected_ref}`);
  } else {
    fail(`Parrainage incorrect: ${refPending} != ${expected_ref}`);
  }

  // Parrain ne peut pas se parrainer lui-même
  await usdt.connect(player1).approve(l2addr, 1000n * 1000000n);
await lottery2.connect(player1).buyTickets(5n, player1.address);
  const selfRef = await lottery2.referrerOf(player1.address);
  if (selfRef === hre.ethers.ZeroAddress) {
    ok("Auto-parrainage bloqué correctement");
  } else {
    fail("Auto-parrainage non bloqué");
  }

  // ─── TEST 5 : updateDistribution validation ───
  console.log("\n5. VALIDATION updateDistribution");
  try {
    await lottery.updateDistribution(5000n,300n,200n,100n,600n,50n);
    fail("Total != 10000 accepté");
  } catch { ok("Total != 10000 rejeté correctement"); }

  try {
    await lottery.updateDistribution(8800n,300n,200n,100n,600n,50n);
    ok("Distribution valide acceptée");
  } catch (e) { fail("Distribution valide rejetée: " + e.message); }

  // ─── RÉSULTAT ───
  console.log(`\n=== RÉSULTAT: ${passed} ✅ / ${failed} ❌ ===`);
  if (failed === 0) {
    console.log("🎉 Contrat prêt pour le déploiement mainnet !");
  } else {
    console.log("⚠️  Des problèmes ont été détectés.");
  }
}

main().catch(console.error);
